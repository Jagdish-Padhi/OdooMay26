{
  "name": "pern-template-server",
  "version": "1.0.0",
  "description": "PERN stack server — Express + PostgreSQL + Drizzle ORM",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --watch src --watch .env src/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "node -r dotenv/config --input-type=module -e \"import('./src/db/seed/cities.seed.js').then((m) => m.seedCities())\"",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint . --config eslint.config.mjs",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@neondatabase/serverless": "^0.10.4",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3"
  }
}
