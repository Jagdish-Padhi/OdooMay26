# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# ─── PostgreSQL (Local Docker) ────────────────────────────────────────────────
# Used when running locally via docker-compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_db

# ─── PostgreSQL (Neon Cloud — deployed fallback) ──────────────────────────────
# Comment out DATABASE_URL above and uncomment this for production/Neon
# DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/neondb?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
